GEMINI_API_KEY=your_gemini_api_key_here
DB_PASSWORD=your_secure_password
JWT_SECRET=your_jwt_secret_min_32_chars_long_here
ENCRYPTION_KEY=your_encryption_secret_min_16_chars_here
REGISTRATION_AUTO_APPROVE=true
# Register this account first, then set its email here and restart the API.
ADMIN_EMAIL=
LONG_TERM_MEMORY_ENABLED=true
# AudioCore is the production voice path. These are global emergency rollback
# switches, not a per-user rollout list.
AUDIO_CORE_AGENT_ENABLED=true
AUDIO_CORE_AGENT_SKIP_PLANNER_ENABLED=true

# Android beta update manifest. Leave LatestVersionCode at 0 to publish no
# update. Raise MinimumSupportedVersionCode only for a breaking client change.
MOBILE_UPDATE_ANDROID_LATEST_VERSION=
MOBILE_UPDATE_ANDROID_LATEST_VERSION_CODE=0
MOBILE_UPDATE_ANDROID_MIN_SUPPORTED_VERSION_CODE=0
MOBILE_UPDATE_ANDROID_DOWNLOAD_URL=
MOBILE_UPDATE_ANDROID_SHA256=
MOBILE_UPDATE_ANDROID_RELEASE_NOTES=
